config mptcp-bonding 'global'
	option enabled '0'
	option convergence_server '192.168.1.100'
	option convergence_port '9001'
	option convergence_password ''

config interface 'wan1'
	option enabled '0'
	option interface 'eth1'
	option weight '100'
	option backup '0'

config interface 'wan2'
	option enabled '0'
	option interface 'eth2'
	option weight '100'
	option backup '0'

config interface 'wan3'
	option enabled '0'
	option interface 'eth3'
	option weight '100'
	option backup '0'

config shadowsocks 'proxy'
	option enabled '0'
	option server '127.0.0.1'
	option server_port '1080'
	option password ''
	option method 'aes-256-gcm'

config mptcp-bonding 'advanced'
	option health_check_interval '30'
	option failover_timeout '10'
	option load_balance_algorithm 'roundrobin'
	option log_level 'info'