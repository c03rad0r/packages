#!/bin/sh /etc/rc.common

START=85
STOP=15
USE_PROCD=1

load_config() {
	local enabled
	config_load 'tollgate'
	config_get_bool enabled 'tollgate' 'enabled' '0'
	[ "$enabled" = "1" ] || return 1
}

start_service() {
	load_config || return 1

	# Create tollgate user if it doesn't exist
	if ! grep -q '^tollgate:' /etc/passwd; then
		adduser -S -D -H -h /etc/tollgate -s /bin/false -g tollgate tollgate
	fi

	# Ensure config directory exists
	mkdir -p /etc/tollgate
	chown tollgate:tollgate /etc/tollgate

	procd_open_instance
	procd_set_param command /usr/bin/tollgate
	procd_set_param pidfile /var/run/tollgate.pid
	procd_set_param user tollgate
	procd_set_param group tollgate
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
	procd_close_instance
}

stop_service() {
	killall tollgate 2>/dev/null
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger 'tollgate'
}