config tollgate 'tollgate'
	option enabled '0'
	option listen_address '0.0.0.0:8080'
	option admin_address '0.0.0.0:8081'
	option interface 'br-lan'
	option gateway_ip '192.168.1.1'

config tollgate 'network'
	option dns_servers '8.8.8.8 8.8.4.4'
	option enable_dhcp '1'
	option dhcp_start '192.168.1.100'
	option dhcp_end '192.168.1.200'
	option dhcp_lease '12h'

config tollgate 'access'
	option default_quota_mb '100'
	option default_duration_hours '24'
	option max_sessions_per_user '5'
	option enable_captive_portal '1'
	option portal_redirect '1'

config tollgate 'payment'
	option rate_mb_per_sat '10'
	option minimum_payment_sats '100'
	option max_balance_sats '10000'
	option mint_url 'https://mint.example.com'

config tollgate 'logging'
	option log_level 'info'
	option log_file '/var/log/tollgate.log'
	option enable_access_log '1'
	option log_rotate_days '7'

config tollgate 'features'
	option enable_statistics '1'
	option enable_webui '1'
	option enable_api '1'
	option enable_monitoring '1'