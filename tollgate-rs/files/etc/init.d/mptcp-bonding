#!/bin/sh /etc/rc.common

START=90
STOP=10
USE_PROCD=1

load_config() {
	local enabled
	config_load 'mptcp-bonding'
	config_get_bool enabled 'global' 'enabled' '0'
	[ "$enabled" = "1" ] || return 1
}

start_service() {
	load_config || return 1

	# Setup MPTCP bonding for each configured interface
	config_foreach setup_interface 'interface'

	# Start shadowsocks proxy if enabled
	local proxy_enabled
	config_get_bool proxy_enabled 'proxy' 'enabled' '0'
	if [ "$proxy_enabled" = "1" ]; then
		start_shadowsocks
	fi

	procd_open_instance
	procd_set_param command /usr/lib/mptcp-bonding/setup-bond.sh
	procd_set_param pidfile /var/run/mptcp-bonding.pid
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
	procd_close_instance
}

setup_interface() {
	local cfg="$1"
	local enabled interface weight backup

	config_get_bool enabled "$cfg" 'enabled' '0'
	[ "$enabled" = "1" ] || return 0

	config_get interface "$cfg" 'interface'
	config_get weight "$cfg" 'weight' '100'
	config_get backup "$cfg" 'backup' '0'

	[ -n "$interface" ] || return 0

	logger "MPTCP bonding: configuring interface $interface (weight: $weight, backup: $backup)"

	# Setup interface for MPTCP
	ip link set $interface up
	ip mptcp endpoint add $interface dev $interface flags subflow
}

start_shadowsocks() {
	local server server_port password method

	config_get server 'proxy' 'server' '127.0.0.1'
	config_get server_port 'proxy' 'server_port' '1080'
	config_get password 'proxy' 'password' ''
	config_get method 'proxy' 'method' 'aes-256-gcm'

	logger "MPTCP bonding: starting shadowsocks proxy on $server:$server_port"

	# Start ss-redir in background
	ss-redir -s "$server" -p "$server_port" -k "$password" -m "$method" -b 0.0.0.0 -l 1081 &
	echo $! > /var/run/ss-redir.pid
}

stop_service() {
	killall setup-bond.sh 2>/dev/null
	killall ss-redir 2>/dev/null
	
	# Clean up MPTCP endpoints
	ip mptcp endpoint flush 2>/dev/null
}

reload_service() {
	stop
	start
}